# ==================== AI Lab-InterReviewer 环境变量配置模板 ====================
# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# ==================== StepFun API Keys（语音TTS/ASR）====================
# 支持最多8个 Key 轮询，至少配置 STEPFUN_API_KEY_1
STEPFUN_API_KEY_1=your_stepfun_api_key_1
STEPFUN_API_KEY_2=
STEPFUN_API_KEY_3=
STEPFUN_API_KEY_4=
STEPFUN_API_KEY_5=
STEPFUN_API_KEY_6=
STEPFUN_API_KEY_7=
STEPFUN_API_KEY_8=

# ==================== 阿里云 DashScope API（LLM + Embedding）====================
DASHSCOPE_API_KEY=your_dashscope_api_key

# ==================== 模型配置（可选，有默认值）====================
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT=60

# TTS 提供者：stepfun 或 edge（edge 为免费）
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-YunjianNeural
TTS_TIMEOUT=30

# ASR 配置
ASR_MODEL=step-asr
ASR_TIMEOUT=30

# ==================== 应用配置（可选）====================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 会话管理
MAX_CONVERSATION_TURNS=50
SESSION_TTL_HOURS=2

# API Key 轮询
API_KEY_MIN_INTERVAL=1.5
API_KEY_MAX_CONCURRENT=4

# ==================== 路径配置（可选）====================
# 向量数据库路径（默认：项目根目录/vector_db）
# VECTOR_DB_PATH=/path/to/custom/vector_db
